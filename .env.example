# =============================================================================
#  .env.example — modelo de variaveis de ambiente (versionavel)
#  Copie para .env e preencha os valores reais. Nunca versione o .env.
# =============================================================================

# --- Django ---
SECRET_KEY=django-insecure-substitua-por-uma-chave-real
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Localizacao ---
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# --- Banco de dados (PostgreSQL) ---
# Use DATABASE_URL ou as variaveis individuais abaixo
DATABASE_URL=postgres://scsi:scsi@localhost:5432/scsi
POSTGRES_DB=scsi
POSTGRES_USER=scsi
POSTGRES_PASSWORD=scsi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (cache + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ (broker) ---
RABBITMQ_DEFAULT_USER=scsi
RABBITMQ_DEFAULT_PASS=scsi
CELERY_BROKER_URL=amqp://scsi:scsi@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- IA / LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-mini
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=

# --- E-mail (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- Producao (ative conforme o ambiente) ---
# SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
# SECURE_REDIRECT_EXEMPT=^/health/?$
